function Test_Settings = set_key_test_settings() 


FD_settings_path =  'P:\GITHUBS\contact_wire_test\SETTINGS_FILES\Test_Settings_new.dat'    ;
Settings_path    =  'C:\Users\Dev\AppData\Roaming\SETTINGS_FILES\Test_Settings_new.dat'    ; 
keyboard


% Buttons
% Reload factory settings
% Save to current
% Exit without change
% new options

Options_.sample_rate_      = {'100000','150000','200000','250000','300000','350000','400000','450000','500000'};
Options_.num_samples       = {'256','512','1024','2048','4096'}      ;
Options_.adc_range_        = {'2.5','5','10'}                        ;
Options_.tone_freq_        = {'40000','50000','60000'}               ;
Options_.num_cycles        = {'1','2','3','4','5','6','7','8'}       ; 
Options_.tone_burst_shape  = {'Square','Triang','Hanning','Guass'}   ;
Options_.num_averages      = {'1','2','4','8','16'}                  ; 

Defaults.SR_index       = 9     ;
Defaults.ADC_index      = 1     ;
Defaults.TF_index       = 2     ; 
Defaults.NC_index       = 6     ;
Defaults.TB_index       = 4     ;
Defaults.NA_index       = 3     ;
Defaults.NS_index       = 4     ;

[fig] = bespoke_dialog_box2(Options_,Defaults);

Test_Settings = [];



end %function Test_Settings = set_key_test_settings(Test_Settings) 


function fig =  bespoke_dialog_box2(Options_,Defaults)

fig = uifigure('Resize','off','Units','normalized','Position',[0.4,0.4,0.2,0.3],'Name', 'Test Settings' );
fig.UserData.button_pressed = 0 ;    
fig.UserData.Warning_message = '' ;
%----------------------------------------------------------------------------------
%ROW 1
%----------------------------------------------------------------------------------
DD_1= uidropdown(fig,"Items",[Options_.sample_rate_],'Position', [15 265 100 28],'FontSize',18,'Value',Options_.sample_rate_{Defaults.SR_index});
lbl = uilabel(fig,'Position',[15 290 150 28],'Text', 'S.Rate(Hz)','FontSize',18)                           ;
fig.UserData.inps.SR_index  = DD_1                                                                 ;

DD_2 =  uidropdown(fig,"Items",[Options_.adc_range_],'Position', [145,265,100,28],'FontSize',18,'Value',Options_.adc_range_{ Defaults.ADC_index}  )   ;
fig.UserData.inps.Contact_wire = DD_2;
lbl2 = uilabel(fig,'Position',[145 290 150 28],'Text', 'DC Range(V)','FontSize',18)                          ;


DD_3= uidropdown(fig,"Items",[Options_.tone_freq_],'Position', [275,265,100,28],'FontSize',18,'Value',Options_.tone_freq_{Defaults.TF_index});
lbl3 = uilabel(fig,'Position',[275 290 150 28],'Text', 'T.B.Freq(Hz)','FontSize',18)                        ;
fig.UserData.inps.TF_index = DD_3                                                                ;
%----------------------------------------------------------------------------------
%ROW 2
%----------------------------------------------------------------------------------
DD_4= uidropdown(fig,"Items",[Options_.num_cycles ],'Position', [15,200,100,28],'FontSize',18,'Value',Options_.num_cycles{Defaults.NC_index})   ;
lbl4 = uilabel(fig,'Position',[15 225 150 28],'Text', 'No Cycles','FontSize',18)                        ;
fig.UserData.inps.NC_index = DD_4                                                                ;

DD_5= uidropdown(fig,"Items",[Options_.tone_burst_shape ],'Position', [145,200,100,28],'FontSize',18,'Value',Options_.tone_burst_shape{Defaults.TB_index})   ;
lbl5 = uilabel(fig,'Position',[145 225 150 28],'Text', 'T.B. Window','FontSize',18)                        ;
fig.UserData.inps.TB_index = DD_5                                                                ;

DD_6= uidropdown(fig,"Items",[Options_.num_averages ],'Position', [275,200,100,28],'FontSize',18,'Value',Options_.num_averages{Defaults.NA_index})   ;
lbl6 = uilabel(fig,'Position',[275 225 150 28],'Text', 'No Averages','FontSize',18)                        ;
fig.UserData.inps.NA_index = DD_6                                                                ;

%----------------------------------------------------------------------------------
%ROW 3
%----------------------------------------------------------------------------------
DD_7= uidropdown(fig,"Items",[Options_.num_samples ],'Position', [145 135 100 28],'FontSize',18,'Value',Options_.num_samples{Defaults.NA_index})   ;
lbl7 = uilabel(fig,'Position',[145 160 100 28],'Text', 'No Samples','FontSize',18)                                           ;
fig.UserData.inps.NA_index = DD_7                                                                                            ;

%----------------------------------------------------------------------------------
%ROW 4 --  Buttons
%----------------------------------------------------------------------------------
but1 = uibutton(fig,"push" ,"Text","Reload FDs",'Position',[5,30,120,55],'FontSize',18,"ButtonPushedFcn", @(src,event)Button1Pushed(fig))   ;

but2 = uibutton(fig,"push" ,"Text","Reload Defs",'Position',[132,30,120,55],'FontSize',18,"ButtonPushedFcn", @(src,event)Button2Pushed(fig))   ;

but3 = uibutton(fig,"push" ,"Text","Save/Exit",'Position',[260,30,120,55],'FontSize',18,"ButtonPushedFcn", @(src,event)Button3Pushed(fig))   ;

end %function bespoke_dialog_box(data_)


